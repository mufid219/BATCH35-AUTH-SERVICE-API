@startuml erd-users

' --- CONFIGURATION ---
skinparam monochrome false
skinparam shadowing false
skinparam linetype ortho
skinparam packageStyle rectangle

title ER-Diagram Auth Schema

' --- ENTITIES ---

entity "roles" as r {
  * **role_id** : NUMBER(10) <<PK>>
  --
  * role_code : VARCHAR2(50) <<UQ>>
  * role_name : VARCHAR2(100)
  description : VARCHAR2(255)
  * is_active : NUMBER(1) [1]
  * created_at : TIMESTAMP
  * updated_at : TIMESTAMP
  * status : VARCHAR2(15)
}

entity "permissions" as p {
  * **permission_id** : NUMBER(10) <<PK>>
  --
  * permission_code : VARCHAR2(100) <<UQ>>
  * module : VARCHAR2(50)
  * action : VARCHAR2(50)
  description : VARCHAR2(255)
  * created_at : TIMESTAMP
}

entity "role_permissions" as rp {
  * **role_id** : NUMBER(10) <<PK>> <<FK>>
  * **permission_id** : NUMBER(10) <<PK>> <<FK>>
  --
  * granted_at : TIMESTAMP
  granted_by : NUMBER(10)
}

entity "users" as u {
  * **user_id** : NUMBER(10) <<PK>>
  --
  * username : VARCHAR2(100) <<UQ>>
  * email : VARCHAR2(150) <<UQ>>
  * password_hash : VARCHAR2(255)
  full_name : VARCHAR2(200)
  phone_number : VARCHAR2(20)
  profile_picture_url : VARCHAR2(500)
  * is_active : NUMBER(1) [0]
  * is_email_verified : NUMBER(1) [0]
  email_verified_at : TIMESTAMP
  * failed_attempts : NUMBER(3) [0]
  locked_until : TIMESTAMP
  last_login_at : TIMESTAMP
  last_login_ip : VARCHAR2(45)
  password_reset_token : VARCHAR2(255)
  password_reset_expires : TIMESTAMP
  * created_at : TIMESTAMP
  * updated_at : TIMESTAMP
  deleted_at : TIMESTAMP
}

entity "user_roles" as ur {
  * **user_id** : NUMBER(10) <<PK>> <<FK>>
  * **role_id** : NUMBER(10) <<PK>> <<FK>>
  --
  * assigned_at : TIMESTAMP
  assigned_by : NUMBER(10)
  expires_at : TIMESTAMP
}

entity "user_tokens" as ut {
  * **token_id** : NUMBER(10) <<PK>>
  --
  * user_id : NUMBER(10) <<FK>>
  * token_type : VARCHAR2(20)
  * token_value : VARCHAR2(500)
  device_info : VARCHAR2(255)
  ip_address : VARCHAR2(45)
  * expires_at : TIMESTAMP
  * is_revoked : NUMBER(1) [0]
  revoked_at : TIMESTAMP
  revoked_by : VARCHAR2(50)
  * created_at : TIMESTAMP
}

entity "otp_codes" as oc {
  * **otp_id** : NUMBER(10) <<PK>>
  --
  * user_id : NUMBER(10) <<FK>>
  * otp_hash : VARCHAR2(255)
  * purpose : VARCHAR2(30)
  * expires_at : TIMESTAMP
  * attempts : NUMBER(3) [0]
  * max_attempts : NUMBER(3) [3]
  * is_used : NUMBER(1) [0]
  used_at : TIMESTAMP
  * created_at : TIMESTAMP
}

entity "audit_logs" as al {
  * **log_id** : NUMBER(10) <<PK>>
  --
  user_id : NUMBER(10) <<FK>>
  * action : VARCHAR2(50)
  * status : VARCHAR2(10)
  ip_address : VARCHAR2(45)
  user_agent : VARCHAR2(500)
  detail : VARCHAR2(1000)
  * created_at : TIMESTAMP
}

' --- RELATIONSHIPS ---

r  ||--|{ rp : "has"
p  ||--|{ rp : "assigned to"

u  ||--|{ ur : "possesses"
r  ||--|{ ur : "assigned to"

u  ||--|{ ut : "generates"
u  ||--|{ oc : "receives"
u  |o--|{ al : "triggers"

@enduml